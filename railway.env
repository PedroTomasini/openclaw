# OpenClaw - Railway Environment Variables
# Cole estas variáveis em: Railway Dashboard → Your Project → Variables

# Server
PORT=8080
NODE_ENV=production

# Gateway Auth (Gere: openssl rand -hex 32)
OPENCLAW_GATEWAY_TOKEN=CHANGE_ME

# Diretórios (volume montado em /data)
OPENCLAW_STATE_DIR=/data/.openclaw
OPENCLAW_WORKSPACE_DIR=/data/workspace

# Provider: Moonshot (Kimi K2.5) - https://platform.moonshot.ai
MOONSHOT_API_KEY=sk-CHANGE_ME

# Forçar pnpm
OPENCLAW_PREFER_PNPM=1
